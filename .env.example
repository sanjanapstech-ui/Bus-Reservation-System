# Copy this file to `.env` for local development.
# Never commit real secrets to git.

SECRET_KEY=change-me

# Option A (recommended): single connection URL from your DB provider (Railway/Aiven/etc.)
# Example: mysql://USER:PASSWORD@HOST:PORT/DBNAME
# MYSQL_URL=mysql://user:password@host:3306/bus_management

# Option B: separate settings
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DB=bus_management
MYSQL_PORT=3306

# Railway sometimes uses these variable names instead (app.py supports them too):
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE

# Optional: protect `/test-db` and `/db-config` in production
DIAGNOSTICS_TOKEN=change-me-too
